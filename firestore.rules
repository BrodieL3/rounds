rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSignedInAs(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCheckedInAt(venueId, uid) {
      let p = /databases/$(database)/documents/venuePresence/$(venueId)/present/$(uid);
      return exists(p) && get(p).data.expiresAt > request.time;
    }

    function requestActorsUnchanged() {
      return request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function idIncludesSignedInUid(id) {
      return signedIn()
        && (id.matches('^' + request.auth.uid + '_.*') || id.matches('.*_' + request.auth.uid + '$'));
    }

    function blockDocPath(blockerUid, blockedUid) {
      return /databases/$(database)/documents/blocks/$(blockerUid + '_' + blockedUid);
    }

    function isBlockedEitherWay(uidA, uidB) {
      return exists(blockDocPath(uidA, uidB)) || exists(blockDocPath(uidB, uidA));
    }

    function signedInUserIsBlockParticipant() {
      return signedIn()
        && (resource.data.blockerUid == request.auth.uid || resource.data.blockedUid == request.auth.uid);
    }

    function dmPairBlocked(data) {
      return data.memberUids is list
        && data.memberUids.size() == 2
        && isBlockedEitherWay(data.memberUids[0], data.memberUids[1]);
    }

    function dmPairBlockedAfter(conversationId) {
      let conversationPath = /databases/$(database)/documents/conversations/$(conversationId);
      return existsAfter(conversationPath)
        && getAfter(conversationPath).data.type == 'dm'
        && dmPairBlocked(getAfter(conversationPath).data);
    }

    function isFriendRequestParticipant() {
      return signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    function validFriendRequestCreate(requestId) {
      return signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && requestId == request.resource.data.fromUid + '_' + request.resource.data.toUid
        && !isBlockedEitherWay(request.resource.data.fromUid, request.resource.data.toUid);
    }

    function validFriendRequestTerminalUpdate(status) {
      return signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == status
        && requestActorsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
    }

    function acceptedRequestForFriendship() {
      let requestId = request.resource.data.createdFromRequestId;
      let requestPath = /databases/$(database)/documents/friendRequests/$(requestId);
      return requestId is string
        && existsAfter(requestPath)
        && getAfter(requestPath).data.status == 'accepted'
        && getAfter(requestPath).data.fromUid in request.resource.data.memberUids
        && getAfter(requestPath).data.toUid in request.resource.data.memberUids;
    }

    function limitedFollowArrayUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
        && request.resource.data.followers is list
        && request.resource.data.following is list
        && request.auth.uid in request.resource.data.followers
        && request.auth.uid in request.resource.data.following;
    }

    function validReplyPreview(data) {
      return data.replyToMessageId is string
        && data.replyToMessageId.size() > 0
        && data.replyToMessageId.size() <= 200
        && data.replyToPreview is map
        && data.replyToPreview.keys().hasOnly(['senderUid', 'type', 'snippet'])
        && data.replyToPreview.senderUid is string
        && data.replyToPreview.senderUid.size() > 0
        && data.replyToPreview.type in ['text', 'venue_link', 'review_link', 'photo', 'voice', 'poll', 'location']
        && data.replyToPreview.snippet is string
        && data.replyToPreview.snippet.size() <= 240;
    }

    function validTextMessageShape(data) {
      return data.keys().hasOnly(['senderUid', 'type', 'text', 'replyToMessageId', 'replyToPreview', 'createdAt', 'deletedForEveryoneAt'])
        && data.senderUid == request.auth.uid
        && data.type == 'text'
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000
        && data.deletedForEveryoneAt == null
        && (!data.keys().hasAny(['replyToMessageId', 'replyToPreview'])
          || (data.keys().hasAll(['replyToMessageId', 'replyToPreview']) && validReplyPreview(data)));
    }

    function validVenueLinkFields(data) {
      return data.venueId is string
        && data.venueId.size() > 0
        && data.venueId.size() <= 200
        && data.venueName is string
        && data.venueName.size() > 0
        && data.venueName.size() <= 160
        && data.venueCohort is string
        && data.venueCohort.size() > 0
        && data.venueCohort.size() <= 80
        && data.venueCity is string
        && data.venueCity.size() > 0
        && data.venueCity.size() <= 80
        && data.venueAddress is string
        && data.venueAddress.size() <= 240;
    }

    function validVenueLinkMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'venueId', 'venueName', 'venueCohort',
          'venueCity', 'venueAddress', 'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'venue_link'
        && validVenueLinkFields(data)
        && data.deletedForEveryoneAt == null;
    }

    function validReviewLinkFields(data) {
      return data.ratingId is string
        && data.ratingId.size() > 0
        && data.ratingId.size() <= 200
        && data.venueId is string
        && data.venueId.size() > 0
        && data.venueId.size() <= 200
        && data.venueName is string
        && data.venueName.size() > 0
        && data.venueName.size() <= 160
        && data.venueCohort is string
        && data.venueCohort.size() > 0
        && data.venueCohort.size() <= 80
        && data.sentiment in ['loved', 'fine', 'disliked']
        && data.authorDisplayName is string
        && data.authorDisplayName.size() <= 160
        && data.authorUsername is string
        && data.authorUsername.size() <= 160
        && data.notes is string
        && data.notes.size() <= 1000
        && (!data.keys().hasAny(['visibility'])
          || data.visibility in ['public', 'unlisted', 'private']);
    }

    function validReviewLinkMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'ratingId', 'venueId', 'venueName', 'venueCohort',
          'sentiment', 'authorDisplayName', 'authorUsername', 'notes', 'visibility',
          'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'review_link'
        && validReviewLinkFields(data)
        && data.deletedForEveryoneAt == null;
    }

    function validPhotoMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'mediaPaths', 'aspectRatios', 'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'photo'
        && data.mediaPaths is list
        && data.mediaPaths.size() >= 1
        && data.mediaPaths.size() <= 10
        && data.aspectRatios is list
        && data.aspectRatios.size() == data.mediaPaths.size()
        && data.deletedForEveryoneAt == null;
    }

    function validVoiceMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'storagePath', 'durationMs', 'format', 'savedBy', 'expiresAt', 'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'voice'
        && data.storagePath is string
        && data.durationMs is int
        && data.durationMs > 0
        && data.durationMs <= 60000
        && data.format == 'm4a'
        && data.savedBy is list
        && data.deletedForEveryoneAt == null;
    }

    function validPollMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'question', 'options', 'allowMultiple', 'allowMemberOptions', 'closesAt', 'closedAt', 'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'poll'
        && data.question is string
        && data.question.size() > 0
        && data.question.size() <= 500
        && data.options is list
        && data.options.size() >= 2
        && data.options.size() <= 20
        && data.allowMultiple is bool
        && data.allowMemberOptions is bool
        && data.deletedForEveryoneAt == null;
    }

    function validLocationMessageShape(data) {
      return data.keys().hasOnly([
          'senderUid', 'type', 'lat', 'lng', 'label', 'createdAt', 'deletedForEveryoneAt'
        ])
        && data.senderUid == request.auth.uid
        && data.type == 'location'
        && data.lat is number
        && data.lng is number
        && data.label is string
        && data.label.size() <= 240
        && data.deletedForEveryoneAt == null;
    }

    function validReactionShape(uid) {
      return isSignedInAs(uid)
        && request.resource.data.keys().hasOnly(['uid', 'emoji', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.emoji in ['👍', '❤️', '😂', '😮', '😢', '🔥'];
    }

    function pollIsOpenForVoting(conversationId, messageId) {
      let messagePath = /databases/$(database)/documents/conversations/$(conversationId)/messages/$(messageId);
      return existsAfter(messagePath)
        && getAfter(messagePath).data.type == 'poll'
        && getAfter(messagePath).data.closedAt == null
        && (getAfter(messagePath).data.closesAt == null || getAfter(messagePath).data.closesAt > request.time);
    }

    function validMessageShape(data) {
      return validTextMessageShape(data)
        || validVenueLinkMessageShape(data)
        || validReviewLinkMessageShape(data)
        || validPhotoMessageShape(data)
        || validVoiceMessageShape(data)
        || validPollMessageShape(data)
        || validLocationMessageShape(data);
    }

    function validLastTextMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'text', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'text'
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000;
    }

    function validLastVenueLinkMessage(data) {
      return data.keys().hasOnly([
          'id', 'senderUid', 'type', 'venueId', 'venueName', 'venueCohort',
          'venueCity', 'venueAddress', 'createdAt'
        ])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'venue_link'
        && validVenueLinkFields(data);
    }

    function validLastReviewLinkMessage(data) {
      return data.keys().hasOnly([
          'id', 'senderUid', 'type', 'ratingId', 'venueId', 'venueName', 'venueCohort',
          'sentiment', 'authorDisplayName', 'authorUsername', 'notes', 'visibility', 'createdAt'
        ])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'review_link'
        && validReviewLinkFields(data);
    }

    function validLastPhotoMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'photoCount', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'photo'
        && data.photoCount is int
        && data.photoCount >= 1
        && data.photoCount <= 10;
    }

    function validLastVoiceMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'voice';
    }

    function validLastPollMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'question', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'poll'
        && data.question is string
        && data.question.size() > 0
        && data.question.size() <= 500;
    }

    function validLastLocationMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'label', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'location'
        && data.label is string
        && data.label.size() <= 240;
    }

    function validLastMessage(data) {
      return validLastTextMessage(data)
        || validLastVenueLinkMessage(data)
        || validLastReviewLinkMessage(data)
        || validLastPhotoMessage(data)
        || validLastVoiceMessage(data)
        || validLastPollMessage(data)
        || validLastLocationMessage(data);
    }

    function friendshipExistsForDmCreate() {
      return exists(/databases/$(database)/documents/friendships/$(request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]));
    }

    function validDmConversationCreate(conversationId) {
      return signedIn()
        && request.resource.data.keys().hasOnly(['type', 'memberUids', 'createdAt', 'createdByUid', 'lastMessageAt', 'lastMessage'])
        && request.resource.data.type == 'dm'
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdByUid == request.auth.uid
        && conversationId == 'dm_' + request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]
        && friendshipExistsForDmCreate()
        && !dmPairBlocked(request.resource.data)
        && validLastMessage(request.resource.data.lastMessage);
    }

    function isConversationMember(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
    }

    function isConversationMemberAfter(conversationId) {
      return signedIn()
        && existsAfter(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
    }

    function activeMemberDocExists(conversationId, uid) {
      let memberPath = /databases/$(database)/documents/conversations/$(conversationId)/members/$(uid);
      return exists(memberPath) && get(memberPath).data.leftAt == null;
    }

    function activeMemberDocExistsAfter(conversationId, uid) {
      let memberPath = /databases/$(database)/documents/conversations/$(conversationId)/members/$(uid);
      return existsAfter(memberPath) && getAfter(memberPath).data.leftAt == null;
    }

    function validConversationMessageUpdate(conversationId) {
      return signedIn()
        && request.auth.uid in resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessageAt', 'lastMessage'])
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.type == resource.data.type
        && validLastMessage(request.resource.data.lastMessage)
        && (resource.data.type != 'dm' || !dmPairBlocked(resource.data))
        && (resource.data.type == 'dm' || activeMemberDocExists(conversationId, request.auth.uid));
    }

    function validConversationMemberCreate(conversationId, memberUid) {
      return isConversationMemberAfter(conversationId)
        && memberUid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids
        && request.resource.data.keys().hasOnly(['uid', 'role', 'joinedAt', 'leftAt'])
        && request.resource.data.uid == memberUid
        && request.resource.data.role == 'member'
        && request.resource.data.leftAt == null;
    }

    function validConversationStateWrite(uid, conversationId) {
      let statePath = /databases/$(database)/documents/users/$(uid)/conversationStates/$(conversationId);
      return signedIn()
        && isConversationMemberAfter(conversationId)
        && uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids
        && (isSignedInAs(uid)
          && request.resource.data.keys().hasOnly(['hiddenAt', 'lastSeenAt', 'deletedForSelfAt', 'hiddenMessageIds', 'pinnedAt'])
          && (!request.resource.data.keys().hasAny(['hiddenMessageIds']) || request.resource.data.hiddenMessageIds is list)
          || !exists(statePath)
            && request.resource.data.keys().hasOnly(['hiddenAt'])
            && request.resource.data.hiddenAt == null);
    }

    function validRatingCreate(ratingId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'userId', 'username', 'displayName', 'userPhotoURL',
          'venueId', 'venueName', 'cohort', 'sentiment', 'notes',
          'mediaPaths', 'companionUids', 'city', 'visibility', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'userId', 'venueId', 'venueName', 'cohort', 'sentiment',
          'notes', 'mediaPaths', 'city', 'visibility', 'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.venueId is string
        && request.resource.data.venueName is string
        && request.resource.data.cohort is string
        && request.resource.data.sentiment in ['loved', 'fine', 'disliked']
        && request.resource.data.notes is string
        && request.resource.data.mediaPaths is list
        && (!request.resource.data.keys().hasAny(['companionUids'])
          || (request.resource.data.companionUids is list
            && request.resource.data.companionUids.size() <= 25))
        && request.resource.data.city is string
        && request.resource.data.visibility in ['public', 'unlisted', 'private'];
    }

    function hasActiveShare(uid, ratingId) {
      let sharePath = /databases/$(database)/documents/users/$(uid)/sharedRatings/$(ratingId);
      return exists(sharePath)
        && get(sharePath).data.revokedAt == null;
    }

    function canReadRating() {
      return resource.data.visibility == 'public'
        || isSignedInAs(resource.data.userId)
        || (signedIn() && hasActiveShare(request.auth.uid, resource.id));
    }

    function publicRatingExistsAfter(ratingId) {
      let ratingPath = /databases/$(database)/documents/ratings/$(ratingId);
      return existsAfter(ratingPath)
        && getAfter(ratingPath).data.userId == request.auth.uid
        && getAfter(ratingPath).data.visibility == 'public';
    }

    function validPostProjectionCreate(postId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'ratingId', 'userId', 'username', 'displayName', 'userPhotoURL',
          'venueId', 'venueName', 'cohort', 'sentiment', 'notes',
          'mediaPaths', 'companionUids', 'city', 'visibility', 'likes', 'likedBy',
          'bookmarks', 'bookmarkedBy', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'ratingId', 'userId', 'venueId', 'venueName', 'cohort',
          'sentiment', 'notes', 'mediaPaths', 'city', 'visibility',
          'likes', 'likedBy', 'bookmarks', 'bookmarkedBy', 'createdAt'
        ])
        && request.resource.data.ratingId == postId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.visibility == 'public'
        && request.resource.data.venueId is string
        && request.resource.data.venueName is string
        && request.resource.data.cohort is string
        && request.resource.data.sentiment in ['loved', 'fine', 'disliked']
        && request.resource.data.notes is string
        && request.resource.data.mediaPaths is list
        && request.resource.data.city is string
        && request.resource.data.likes == 0
        && request.resource.data.likedBy == []
        && request.resource.data.bookmarks == 0
        && request.resource.data.bookmarkedBy == []
        && publicRatingExistsAfter(postId);
    }

    function validSelfOnlyArrayToggle(oldList, newList) {
      return signedIn()
        && oldList is list
        && newList is list
        && (
          (!(request.auth.uid in oldList)
            && request.auth.uid in newList
            && newList.size() == oldList.size() + 1
            && newList.hasAll(oldList))
          || (request.auth.uid in oldList
            && !(request.auth.uid in newList)
            && newList.size() == oldList.size() - 1
            && oldList.hasAll(newList))
        );
    }

    function validPostLikeUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])
        && request.resource.data.likedBy is list
        && request.resource.data.likes == request.resource.data.likedBy.size()
        && validSelfOnlyArrayToggle(resource.data.likedBy, request.resource.data.likedBy);
    }

    function validPostBookmarkUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookmarks', 'bookmarkedBy'])
        && request.resource.data.bookmarkedBy is list
        && request.resource.data.bookmarks == request.resource.data.bookmarkedBy.size()
        && validSelfOnlyArrayToggle(resource.data.bookmarkedBy, request.resource.data.bookmarkedBy);
    }

    function validSafetyReportCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'reporterUid', 'targetType', 'targetId', 'conversationId', 'messageId',
          'ratingId', 'reportedUid', 'reason', 'createdAt', 'status'
        ])
        && request.resource.data.keys().hasAll(['reporterUid', 'targetType', 'targetId', 'reason', 'createdAt', 'status'])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType in ['user', 'message', 'group', 'review_tag']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 1000
        && request.resource.data.status == 'open';
    }

    function validLegacyVenueReportCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly(['userId', 'venueId', 'venueName', 'suggestedCohort', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.venueId is string
        && request.resource.data.venueName is string
        && request.resource.data.suggestedCohort is string;
    }

    // Users: public read, self write; limited follower/following writes support beta social graph.
    match /users/{uid} {
      allow read: if true;
      allow create: if isSignedInAs(uid);
      allow update: if isSignedInAs(uid) || limitedFollowArrayUpdate();
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read: if isSignedInAs(uid);
        allow create: if signedIn()
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.type in ['friend_request_received', 'friend_request_accepted', 'new_direct_message', 'new_group_message']
          && request.resource.data.keys().hasOnly(['type', 'actorUid', 'conversationId', 'createdAt', 'readAt']);
        allow update, delete: if false;
      }

      match /conversationStates/{conversationId} {
        allow read: if isSignedInAs(uid);
        allow create, update: if validConversationStateWrite(uid, conversationId);
        allow delete: if false;
      }
    }

    // Blocks: private to participants, written by trusted Cloud Functions.
    match /blocks/{blockId} {
      allow get: if idIncludesSignedInUid(blockId);
      allow list: if signedInUserIsBlockParticipant();
      allow create, update, delete: if false;
    }

    // Friend requests: private to requester and recipient.
    match /friendRequests/{requestId} {
      allow get: if idIncludesSignedInUid(requestId);
      allow list: if isFriendRequestParticipant();
      allow create: if validFriendRequestCreate(requestId);
      allow update: if validFriendRequestTerminalUpdate('canceled')
          && resource.data.fromUid == request.auth.uid
        || validFriendRequestTerminalUpdate('declined')
          && resource.data.toUid == request.auth.uid
        || validFriendRequestTerminalUpdate('accepted')
          && resource.data.toUid == request.auth.uid
          && !isBlockedEitherWay(resource.data.fromUid, resource.data.toUid);
      allow delete: if false;
    }

    // Friendships: private to members, created after an accepted Friend Request.
    match /friendships/{friendshipId} {
      allow get: if idIncludesSignedInUid(friendshipId);
      allow list: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn()
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids
        && friendshipId == request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]
        && !isBlockedEitherWay(request.resource.data.memberUids[0], request.resource.data.memberUids[1])
        && acceptedRequestForFriendship();
      allow update, delete: if false;
    }

    // Conversations: private to members; DM creation requires Friendship.
    match /conversations/{conversationId} {
      allow get, list: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if validDmConversationCreate(conversationId);
      allow update: if validConversationMessageUpdate(conversationId);
      allow delete: if false;

      match /members/{memberUid} {
        allow read: if isConversationMember(conversationId);
        allow create: if validConversationMemberCreate(conversationId, memberUid);
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMemberAfter(conversationId)
          && validMessageShape(request.resource.data)
          && !dmPairBlockedAfter(conversationId)
          && (getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.type == 'dm'
            || activeMemberDocExistsAfter(conversationId, request.auth.uid));
        allow update, delete: if false;

        match /reactions/{uid} {
          allow read: if isConversationMember(conversationId);
          allow create, update: if isConversationMember(conversationId) && validReactionShape(uid);
          allow delete: if isSignedInAs(uid) && isConversationMember(conversationId);
        }
      }
    }

    // Poll votes: deferred to fast-follow. Closed poll enforcement lives in client service layer.
    // The Firestore rules emulator has a pre-evaluation bug with deeply nested subcollection
    // rules during parent document writes; vote rules are enforced client-side via canVoteInPoll.

    // Reviews: legacy read only. New canonical writes use ratings/{ratingId}.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Ratings: canonical opinion/review object.
    match /ratings/{ratingId} {
      allow read: if canReadRating();
      allow create: if validRatingCreate(ratingId);
      allow update, delete: if false;
    }

    // Comparisons: public read, self write. New writes MUST be versioned (v2,
    // ADR 009 §5) so no thin/legacy-shaped record can poison Tier B (the global
    // BT leaderboard). Field-level v2 completeness is enforced in
    // lib/comparisons/comparison-payload.js; existing stored docs are unaffected
    // (rules gate writes, not reads).
    match /comparisons/{comparisonId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.schemaVersion is int
        && request.resource.data.cohort is string
        && request.resource.data.venueA is string
        && request.resource.data.venueB is string
        && request.resource.data.venueA != request.resource.data.venueB
        && request.resource.data.result is string;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Posts: interim public projection for public Ratings.
    match /posts/{postId} {
      allow read: if true;
      allow create: if validPostProjectionCreate(postId);
      allow update: if validPostLikeUpdate() || validPostBookmarkUpdate();
      allow delete: if false;

      // Comments: public read, authenticated self create, blocked-user interaction denied.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && !isBlockedEitherWay(request.auth.uid, get(/databases/$(database)/documents/posts/$(postId)).data.userId);
        allow update, delete: if false;
      }
    }

    // Feed items: owner-only read, backend write
    match /feedItems/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // written by backend only

      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Reports: authenticated users can create safe report shapes, no client read.
    match /reports/{reportId} {
      allow create: if validSafetyReportCreate() || validLegacyVenueReportCreate();
      allow read, update, delete: if false;
    }

    // Venue bookmarks: private owner-only read/write.
    match /users/{uid}/venueBookmarks/{venueId} {
      allow read, write, delete: if isSignedInAs(uid);
    }

    // Shared ratings: owner-only read. Written by trusted Cloud Functions.
    match /users/{uid}/sharedRatings/{ratingId} {
      allow read: if isSignedInAs(uid);
      allow create, update, delete: if false;
    }

    // Rating shares: readable by conversation members. Written by trusted Cloud Functions.
    match /ratings/{ratingId}/shares/{conversationId} {
      allow read: if signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
      allow create, update, delete: if false;
    }

    // Leaderboard entries: public read, backend write
    match /leaderboardEntries/{city}/{cohort}/entries/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Events: public read, server-only write (seed script + P4 ingestion via admin SDK).
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Happy hours: public read, server-only write.
    match /happyHours/{happyHourId} {
      allow read: if true;
      allow write: if false;
    }

    // Venue presence: a user's own check-in record. expiresAt is a Timestamp so
    // rules can compare it to request.time. One doc per uid per venue.
    match /venuePresence/{venueId}/present/{uid} {
      allow read: if signedIn();
      allow create, update: if isSignedInAs(uid) && request.resource.data.uid == uid;
      allow delete: if isSignedInAs(uid); // manual checkout
    }

    // Venue forum: ephemeral room. Signed-in read; posts only by users currently
    // checked in (non-expired presence), authored as themselves. Immutable —
    // cleared server-side each night.
    match /venueForums/{venueId}/messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isCheckedInAt(venueId, request.auth.uid);
      allow update, delete: if false;
    }

    // Connection tokens: a user mints their own ephemeral QR token. Resolved only
    // by the trusted resolveConnectionToken Function (admin) — never client-read,
    // never client-mutated (consumption happens server-side).
    match /connectionTokens/{token} {
      allow read: if false;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
