rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSignedInAs(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function requestActorsUnchanged() {
      return request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function idIncludesSignedInUid(id) {
      return signedIn()
        && (id.matches('^' + request.auth.uid + '_.*') || id.matches('.*_' + request.auth.uid + '$'));
    }

    function isFriendRequestParticipant() {
      return signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    function validFriendRequestCreate(requestId) {
      return signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && requestId == request.resource.data.fromUid + '_' + request.resource.data.toUid;
    }

    function validFriendRequestTerminalUpdate(status) {
      return signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == status
        && requestActorsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
    }

    function acceptedRequestForFriendship() {
      let requestId = request.resource.data.createdFromRequestId;
      let requestPath = /databases/$(database)/documents/friendRequests/$(requestId);
      return requestId is string
        && existsAfter(requestPath)
        && getAfter(requestPath).data.status == 'accepted'
        && getAfter(requestPath).data.fromUid in request.resource.data.memberUids
        && getAfter(requestPath).data.toUid in request.resource.data.memberUids;
    }

    function limitedFollowArrayUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
        && request.resource.data.followers is list
        && request.resource.data.following is list
        && request.auth.uid in request.resource.data.followers
        && request.auth.uid in request.resource.data.following;
    }

    function validTextMessageShape(data) {
      return data.keys().hasOnly(['senderUid', 'type', 'text', 'createdAt', 'deletedForEveryoneAt'])
        && data.senderUid == request.auth.uid
        && data.type == 'text'
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000
        && data.deletedForEveryoneAt == null;
    }

    function validLastTextMessage(data) {
      return data.keys().hasOnly(['id', 'senderUid', 'type', 'text', 'createdAt'])
        && data.id is string
        && data.senderUid == request.auth.uid
        && data.type == 'text'
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000;
    }

    function friendshipExistsForDmCreate() {
      return exists(/databases/$(database)/documents/friendships/$(request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]));
    }

    function validDmConversationCreate(conversationId) {
      return signedIn()
        && request.resource.data.keys().hasOnly(['type', 'memberUids', 'createdAt', 'createdByUid', 'lastMessageAt', 'lastMessage'])
        && request.resource.data.type == 'dm'
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdByUid == request.auth.uid
        && conversationId == 'dm_' + request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]
        && friendshipExistsForDmCreate()
        && validLastTextMessage(request.resource.data.lastMessage);
    }

    function isConversationMember(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
    }

    function isConversationMemberAfter(conversationId) {
      return signedIn()
        && existsAfter(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
    }

    function activeMemberDocExists(conversationId, uid) {
      let memberPath = /databases/$(database)/documents/conversations/$(conversationId)/members/$(uid);
      return exists(memberPath) && get(memberPath).data.leftAt == null;
    }

    function activeMemberDocExistsAfter(conversationId, uid) {
      let memberPath = /databases/$(database)/documents/conversations/$(conversationId)/members/$(uid);
      return existsAfter(memberPath) && getAfter(memberPath).data.leftAt == null;
    }

    function validConversationTextUpdate(conversationId) {
      return signedIn()
        && request.auth.uid in resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessageAt', 'lastMessage'])
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.type == resource.data.type
        && validLastTextMessage(request.resource.data.lastMessage)
        && (resource.data.type == 'dm' || activeMemberDocExists(conversationId, request.auth.uid));
    }

    function validConversationMemberCreate(conversationId, memberUid) {
      return isConversationMemberAfter(conversationId)
        && memberUid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids
        && request.resource.data.keys().hasOnly(['uid', 'role', 'joinedAt', 'leftAt'])
        && request.resource.data.uid == memberUid
        && request.resource.data.role == 'member'
        && request.resource.data.leftAt == null;
    }

    function validConversationStateWrite(uid, conversationId) {
      let statePath = /databases/$(database)/documents/users/$(uid)/conversationStates/$(conversationId);
      return signedIn()
        && isConversationMemberAfter(conversationId)
        && uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids
        && (isSignedInAs(uid)
          && request.resource.data.keys().hasOnly(['hiddenAt', 'lastSeenAt'])
          || !exists(statePath)
            && request.resource.data.keys().hasOnly(['hiddenAt'])
            && request.resource.data.hiddenAt == null);
    }

    function validRatingCreate(ratingId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'userId', 'username', 'displayName', 'userPhotoURL',
          'venueId', 'venueName', 'cohort', 'sentiment', 'notes',
          'mediaPaths', 'city', 'visibility', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'userId', 'venueId', 'venueName', 'cohort', 'sentiment',
          'notes', 'mediaPaths', 'city', 'visibility', 'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.venueId is string
        && request.resource.data.venueName is string
        && request.resource.data.cohort is string
        && request.resource.data.sentiment in ['loved', 'fine', 'disliked']
        && request.resource.data.notes is string
        && request.resource.data.mediaPaths is list
        && request.resource.data.city is string
        && request.resource.data.visibility in ['public', 'unlisted', 'private'];
    }

    function canReadRating() {
      return resource.data.visibility == 'public'
        || isSignedInAs(resource.data.userId);
    }

    function publicRatingExistsAfter(ratingId) {
      let ratingPath = /databases/$(database)/documents/ratings/$(ratingId);
      return existsAfter(ratingPath)
        && getAfter(ratingPath).data.userId == request.auth.uid
        && getAfter(ratingPath).data.visibility == 'public';
    }

    function validPostProjectionCreate(postId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'ratingId', 'userId', 'username', 'displayName', 'userPhotoURL',
          'venueId', 'venueName', 'cohort', 'sentiment', 'notes',
          'mediaPaths', 'city', 'visibility', 'likes', 'likedBy',
          'bookmarks', 'bookmarkedBy', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'ratingId', 'userId', 'venueId', 'venueName', 'cohort',
          'sentiment', 'notes', 'mediaPaths', 'city', 'visibility',
          'likes', 'likedBy', 'bookmarks', 'bookmarkedBy', 'createdAt'
        ])
        && request.resource.data.ratingId == postId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.visibility == 'public'
        && request.resource.data.venueId is string
        && request.resource.data.venueName is string
        && request.resource.data.cohort is string
        && request.resource.data.sentiment in ['loved', 'fine', 'disliked']
        && request.resource.data.notes is string
        && request.resource.data.mediaPaths is list
        && request.resource.data.city is string
        && request.resource.data.likes == 0
        && request.resource.data.likedBy == []
        && request.resource.data.bookmarks == 0
        && request.resource.data.bookmarkedBy == []
        && publicRatingExistsAfter(postId);
    }

    // Users: public read, self write; limited follower/following writes support beta social graph.
    match /users/{uid} {
      allow read: if true;
      allow create: if isSignedInAs(uid);
      allow update: if isSignedInAs(uid) || limitedFollowArrayUpdate();
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read: if isSignedInAs(uid);
        allow create: if signedIn()
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.type in ['friend_request_received', 'friend_request_accepted', 'new_direct_message', 'new_group_message'];
        allow update, delete: if false;
      }

      match /conversationStates/{conversationId} {
        allow read: if isSignedInAs(uid);
        allow create, update: if validConversationStateWrite(uid, conversationId);
        allow delete: if false;
      }
    }

    // Friend requests: private to requester and recipient.
    match /friendRequests/{requestId} {
      allow get: if idIncludesSignedInUid(requestId);
      allow list: if isFriendRequestParticipant();
      allow create: if validFriendRequestCreate(requestId);
      allow update: if validFriendRequestTerminalUpdate('canceled')
          && resource.data.fromUid == request.auth.uid
        || validFriendRequestTerminalUpdate('declined')
          && resource.data.toUid == request.auth.uid
        || validFriendRequestTerminalUpdate('accepted')
          && resource.data.toUid == request.auth.uid;
      allow delete: if false;
    }

    // Friendships: private to members, created after an accepted Friend Request.
    match /friendships/{friendshipId} {
      allow get: if idIncludesSignedInUid(friendshipId);
      allow list: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn()
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids
        && friendshipId == request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]
        && acceptedRequestForFriendship();
      allow update, delete: if false;
    }

    // Conversations: private to members; DM creation requires Friendship.
    match /conversations/{conversationId} {
      allow get, list: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if validDmConversationCreate(conversationId);
      allow update: if validConversationTextUpdate(conversationId);
      allow delete: if false;

      match /members/{memberUid} {
        allow read: if isConversationMember(conversationId);
        allow create: if validConversationMemberCreate(conversationId, memberUid);
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMemberAfter(conversationId)
          && validTextMessageShape(request.resource.data)
          && (getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.type == 'dm'
            || activeMemberDocExistsAfter(conversationId, request.auth.uid));
        allow update, delete: if false;
      }
    }

    // Reviews: legacy read only. New canonical writes use ratings/{ratingId}.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Ratings: canonical opinion/review object.
    match /ratings/{ratingId} {
      allow read: if canReadRating();
      allow create: if validRatingCreate(ratingId);
      allow update, delete: if false;
    }

    // Comparisons: public read, self write
    match /comparisons/{comparisonId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Posts: interim public projection for public Ratings.
    match /posts/{postId} {
      allow read: if true;
      allow create: if validPostProjectionCreate(postId);
      allow update, delete: if false;

      // Comments: public read, authenticated self create
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Feed items: owner-only read, backend write
    match /feedItems/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // written by backend only

      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Reports: authenticated users can create, no read
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Venue bookmarks: private owner-only read/write.
    match /users/{uid}/venueBookmarks/{venueId} {
      allow read, write, delete: if isSignedInAs(uid);
    }

    // Leaderboard entries: public read, backend write
    match /leaderboardEntries/{city}/{cohort}/entries/{userId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
