rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSignedInAs(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function requestActorsUnchanged() {
      return request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function idIncludesSignedInUid(id) {
      return signedIn()
        && (id.matches('^' + request.auth.uid + '_.*') || id.matches('.*_' + request.auth.uid + '$'));
    }

    function isFriendRequestParticipant() {
      return signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    function validFriendRequestCreate(requestId) {
      return signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && requestId == request.resource.data.fromUid + '_' + request.resource.data.toUid;
    }

    function validFriendRequestTerminalUpdate(status) {
      return signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == status
        && requestActorsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);
    }

    function acceptedRequestForFriendship() {
      let requestId = request.resource.data.createdFromRequestId;
      let requestPath = /databases/$(database)/documents/friendRequests/$(requestId);
      return requestId is string
        && existsAfter(requestPath)
        && getAfter(requestPath).data.status == 'accepted'
        && getAfter(requestPath).data.fromUid in request.resource.data.memberUids
        && getAfter(requestPath).data.toUid in request.resource.data.memberUids;
    }

    function limitedFollowArrayUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
        && request.resource.data.followers is list
        && request.resource.data.following is list
        && request.auth.uid in request.resource.data.followers
        && request.auth.uid in request.resource.data.following;
    }

    // Users: public read, self write; limited follower/following writes support beta social graph.
    match /users/{uid} {
      allow read: if true;
      allow create: if isSignedInAs(uid);
      allow update: if isSignedInAs(uid) || limitedFollowArrayUpdate();
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read: if isSignedInAs(uid);
        allow create: if signedIn()
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.type in ['friend_request_received', 'friend_request_accepted'];
        allow update, delete: if false;
      }
    }

    // Friend requests: private to requester and recipient.
    match /friendRequests/{requestId} {
      allow get: if idIncludesSignedInUid(requestId);
      allow list: if isFriendRequestParticipant();
      allow create: if validFriendRequestCreate(requestId);
      allow update: if validFriendRequestTerminalUpdate('canceled')
          && resource.data.fromUid == request.auth.uid
        || validFriendRequestTerminalUpdate('declined')
          && resource.data.toUid == request.auth.uid
        || validFriendRequestTerminalUpdate('accepted')
          && resource.data.toUid == request.auth.uid;
      allow delete: if false;
    }

    // Friendships: private to members, created after an accepted Friend Request.
    match /friendships/{friendshipId} {
      allow get: if idIncludesSignedInUid(friendshipId);
      allow list: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn()
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids
        && friendshipId == request.resource.data.memberUids[0] + '_' + request.resource.data.memberUids[1]
        && acceptedRequestForFriendship();
      allow update, delete: if false;
    }

    // Reviews: public read, self write
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }

    // Ratings: public read, self write
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Comparisons: public read, self write
    match /comparisons/{comparisonId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Posts: public read, self write
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Comments: public read, authenticated self create
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Feed items: owner-only read, backend write
    match /feedItems/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // written by backend only

      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Reports: authenticated users can create, no read
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Leaderboard entries: public read, backend write
    match /leaderboardEntries/{city}/{cohort}/entries/{userId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
